{
  "expo": {
    "name": "WANDERING YACHT",
    "slug": "wandering-yacht",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wanderingyacht",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.judyblue22.wanderingyacht",
      "buildNumber": "7",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Sign in quickly with Face ID",
        "NSCameraUsageDescription": "Take photos for your profile or to share your experience",
        "NSPhotoLibraryUsageDescription": "Select photos from your library to share",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d1b2a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.judyblue22.wanderingyacht",
      "permissions": [
        "USE_BIOMETPCICK",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/wy-logo-solid.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d1b2a"
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Sign in quickly with Face ID"
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ebe296e8-2e1b-4e06-bbea-2023ca0aa483"
      }
    }
  }
}
